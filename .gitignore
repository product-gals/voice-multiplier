# macOS
.DS_Store

# Local Claude Code state (per-user, not shared)
.claude/settings.local.json
.claude/*.lock

# Safety belt — also covered by web/.gitignore, but doubling here so a stray
# .env at the root never ships
.env
.env.local
.env.*.local
web/.env.local

# Node / Next.js (also covered by web/.gitignore)
node_modules/
.next/

# Logs
*.log

# Originator corpus — built from the user's LinkedIn data export, contains
# personal post content, never commit
web/data/posts.json
.vercel
